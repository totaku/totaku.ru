---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { analyticsServices } from '@/config/analytics';

const lastUpdated = new Date('2026-04-03').toLocaleDateString('ru-RU', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
});
---

<BaseLayout
    title="Политика конфиденциальности — Totaku"
    description="Информация о сборе и обработке данных на сайте totaku.ru"
>
    <div class="post-wrap">
        <a href="/" class="back-link post-back">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>На главную
        </a>

        <h1 class="post-title">Политика конфиденциальности</h1>

        <div class="post-meta">
            <div class="post-meta-dates">
                <time>Последнее обновление: {lastUpdated}</time>
            </div>
        </div>

        <article class="prose">

            <h2>Введение</h2>
            <p>
                Этот сайт уважает вашу конфиденциальность. Документ объясняет, какие данные собираются, зачем и как вы можете контролировать их использование.
            </p>
            <p>
                Собирается <strong>минимум данных</strong>, необходимых для улучшения сайта.
            </p>

            <h2>Используемые сервисы</h2>
            <p>На сайте используются следующие сервисы для сбора статистики:</p>

            {analyticsServices.filter((s) => s.enabled).map((service) => (
                <div class="service-card">
                    <h3>{service.name}</h3>
                    <p>{service.description}</p>
                    <div class="service-card-links">
                        <a href={service.privacyUrl} target="_blank" rel="noopener noreferrer">
                            Политика конфиденциальности ↗
                        </a>
                        {service.optOutUrl && (
                            <a href={service.optOutUrl} target="_blank" rel="noopener noreferrer">
                                Как отключить ↗
                            </a>
                        )}
                    </div>
                </div>
            ))}

            <h2>Какие данные собираются</h2>
            <ul>
                <li><strong>Анонимная статистика посещений:</strong> просмотренные страницы, время на сайте, источник перехода</li>
                <li><strong>Технические данные:</strong> тип устройства, браузер, операционная система</li>
                <li><strong>Поведение на сайте:</strong> карты кликов, скролл (через вебвизор Яндекс.Метрики)</li>
            </ul>

            <h2>Что не собирается</h2>
            <ul>
                <li>Личные данные (имя, email, телефон)</li>
                <li>Финансовая информация</li>
                <li>Точная геолокация (только регион/город)</li>
            </ul>

            <h2>Использование cookies</h2>
            <p>Cookies используются для работы аналитики и сохранения ваших предпочтений. Все cookies анонимны и не содержат личной информации.</p>

            <table>
                <thead>
                    <tr>
                        <th>Cookie</th>
                        <th>Назначение</th>
                        <th>Срок</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><code>analytics-consent</code></td>
                        <td>Хранит ваше согласие на аналитику</td>
                        <td>Бессрочно</td>
                    </tr>
                    <tr>
                        <td><code>_ym_*</code></td>
                        <td>Яндекс.Метрика</td>
                        <td>1 год</td>
                    </tr>
                </tbody>
            </table>

            <h2>Ваши права</h2>
            <p>Вы можете в любой момент отозвать согласие на аналитику:</p>

            <div class="revoke-block">
                <button id="revoke-consent-button" class="revoke-btn">
                    Отозвать согласие
                </button>
                <span id="revoke-feedback" class="revoke-feedback"></span>
                <p class="revoke-hint">После отзыва аналитика будет отключена.</p>
            </div>

            <h2>Контакты</h2>
            <p>
                Если есть вопросы о конфиденциальности, пишите:
            </p>
            <ul>
                <li><a href="https://t.me/totaku" target="_blank" rel="noopener noreferrer">Telegram</a></li>
                <li><a href="mailto:admin@totaku.su">admin@totaku.su</a></li>
            </ul>

            <h2>Изменения в политике</h2>
            <p>Политика может обновляться. Дата последнего обновления указана в начале документа.</p>
        </article>
    </div>
</BaseLayout>


<style>
    /* Таблица */
    .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5em 0;
        font-size: 0.9rem;
        font-family: 'Manrope', sans-serif;
    }
    .prose thead tr {
        border-bottom: 2px solid var(--border-mid);
    }
    .prose th {
        text-align: left;
        padding: 0.6em 1em;
        font-weight: 700;
        color: var(--text-muted);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .prose td {
        padding: 0.7em 1em;
        border-bottom: 1px solid var(--border);
        color: var(--text-dim);
        vertical-align: top;
    }
    .prose tbody tr:last-child td {
        border-bottom: none;
    }

    /* Карточки сервисов */
    .service-card {
        background: var(--bg-card);
        border: 1px solid var(--border-mid);
        border-radius: 12px;
        padding: 1.25rem;
        margin: 1rem 0;
    }
    .service-card h3 {
        margin: 0 0 0.4em !important;
        font-size: 1rem !important;
    }
    .service-card p {
        margin: 0 0 0.75em !important;
        font-size: 0.9rem;
        color: var(--text-dim);
    }
    .service-card-links {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        font-size: 0.85rem;
        font-family: 'Manrope', sans-serif;
    }
    .service-card-links a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.15s;
    }
    .service-card-links a:hover {
        border-color: var(--accent);
    }

    /* Кнопка отзыва */
    .revoke-block {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin: 1.25rem 0 1.75rem;
    }
    .revoke-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        cursor: pointer;
        background: transparent;
        border: 1px solid var(--border-mid);
        border-radius: 8px;
        padding: 0.55rem 1.1rem;
        font-size: 0.875rem;
        font-weight: 600;
        font-family: 'Manrope', sans-serif;
        color: var(--text-muted);
        transition: border-color 0.15s, color 0.15s;
        width: fit-content;
    }
    .revoke-btn:hover:not(:disabled) {
        border-color: var(--text-muted);
        color: var(--text);
    }
    .revoke-btn:disabled {
        opacity: 0.5;
        cursor: default;
    }
    .revoke-feedback {
        font-size: 0.8rem;
        color: var(--text-dim);
        font-family: 'Manrope', sans-serif;
        min-height: 1em;
    }
    .revoke-hint {
        font-size: 0.8rem !important;
        color: var(--text-muted) !important;
        margin: 0 !important;
        font-family: 'Manrope', sans-serif;
    }
</style>

<script>
    function initRevokeButton() {
        const button = document.getElementById('revoke-consent-button');
        if (!button) return;

        const feedback = document.getElementById('revoke-feedback');

        button.addEventListener('click', () => {
            localStorage.removeItem('analytics-consent');
            localStorage.removeItem('analytics-consent-date');
            button.disabled = true;
            button.textContent = 'Отозвано';
            if (feedback) feedback.textContent = 'Страница перезагрузится через секунду…';
            setTimeout(() => window.location.reload(), 1200);
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRevokeButton);
    } else {
        initRevokeButton();
    }
</script>

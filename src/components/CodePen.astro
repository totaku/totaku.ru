---
interface Props {
    id: string;
    height?: number;
    tab?: string;
}
const { id, height = 500, tab = 'result' } = Astro.props;
---

<script
    is:inline
    data-slug-hash={id}
    data-height={height}
    data-default-tab={tab}
    data-theme-id="8862"
    class="codepen"
    async
    src="https://cpwebassets.codepen.io/assets/embed/ei.js"></script>

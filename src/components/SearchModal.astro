---
---

<!-- Overlay -->
<div
    id="search-overlay"
    class="search-overlay"
    aria-hidden="true"
>
    <div class="search-container">
        <div class="search-modal" role="dialog" aria-modal="true" aria-label="Поиск">
            <!-- Input -->
            <div class="search-header">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input
                    id="search-input"
                    type="text"
                    placeholder="Поиск по статьям..."
                    class="search-input"
                    autocomplete="off"
                    aria-label="Поиск"
                />
                <button id="search-close" class="search-close" aria-label="Закрыть поиск">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>

            <!-- Results -->
            <div id="search-results" class="search-results">
                <div id="search-state-empty" class="search-state">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <p>Введите запрос для поиска</p>
                </div>
                <div id="search-state-loading" class="search-state hidden">
                    <div class="search-spinner"></div>
                    <p>Поиск...</p>
                </div>
                <div id="search-state-empty-results" class="search-state hidden">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/>
                    </svg>
                    <p>Ничего не найдено</p>
                </div>
                <ul id="search-list" class="search-list hidden"></ul>
            </div>

            <!-- Footer -->
            <div class="search-footer">
                <kbd>ESC</kbd> — закрыть &nbsp;·&nbsp; <kbd>⌘K</kbd> — открыть
            </div>
        </div>
    </div>
</div>

<style>
    .search-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(4px);
        z-index: 500;
        display: none;
        opacity: 0;
        transition: opacity 0.15s;
    }

    .search-overlay.visible {
        display: flex;
        opacity: 1;
    }

    .search-container {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        width: 100%;
        padding: 5rem 1rem 2rem;
    }

    .search-modal {
        width: 100%;
        max-width: 40rem;
        background: var(--bg-card);
        border: 1px solid var(--border-mid);
        border-radius: 0.75rem;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
        opacity: 0;
        transform: scale(0.96) translateY(-8px);
        transition: opacity 0.15s, transform 0.15s;
    }

    .search-overlay.visible .search-modal {
        opacity: 1;
        transform: scale(1) translateY(0);
    }

    .search-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.125rem;
        border-bottom: 1px solid var(--border);
        color: var(--text-muted);
    }

    .search-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        font-size: 1rem;
        color: var(--text);
        font-family: inherit;
    }

    .search-input::placeholder { color: var(--text-muted); }

    .search-close {
        background: transparent;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        padding: 0.25rem;
        border-radius: 0.25rem;
        transition: color 0.15s;
        line-height: 0;
    }

    .search-close:hover { color: var(--text); }

    .search-results {
        max-height: 60vh;
        overflow-y: auto;
        padding: 0.75rem;
        scrollbar-width: thin;
        scrollbar-color: var(--border-mid) transparent;
    }

    .search-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        padding: 2.5rem 1rem;
        color: var(--text-muted);
        font-size: 0.875rem;
    }

    .search-state p { margin: 0; }

    .search-spinner {
        width: 2rem;
        height: 2rem;
        border: 2px solid var(--border);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .search-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
    }

    .search-footer {
        padding: 0.625rem 1.125rem;
        border-top: 1px solid var(--border);
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .search-footer kbd {
        padding: 0.15rem 0.4rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 0.25rem;
        font-family: inherit;
        font-size: 0.7rem;
    }

    .hidden { display: none !important; }

    /* Результат поиска */
    :global(.search-result) {
        display: block;
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        text-decoration: none;
        transition: border-color 0.15s, background 0.15s;
        animation: resultIn 0.15s ease;
    }

    :global(.search-result:hover) {
        border-color: var(--accent);
        background: var(--bg-card);
    }

    @keyframes resultIn {
        from { opacity: 0; transform: translateY(-4px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    :global(.search-result-title) {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text);
        margin: 0 0 0.25rem;
    }

    :global(.search-result-excerpt) {
        font-size: 0.8125rem;
        color: var(--text-muted);
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    :global(.search-result-excerpt mark) {
        background: color-mix(in srgb, var(--accent) 25%, transparent);
        color: var(--text);
        padding: 0 0.15rem;
        border-radius: 0.125rem;
    }
</style>

<script>
    declare global {
        interface Window { openSearchModal?: () => void; }
    }

    interface PagefindResult {
        id: string;
        data: () => Promise<{ url: string; excerpt: string; meta: { title: string } }>;
    }

    let pagefind: { search: (q: string) => Promise<{ results: PagefindResult[] }> } | null = null;

    async function loadPagefind() {
        if (pagefind) return pagefind;
        if (import.meta.env.DEV) return null;
        try {
            // Конкатенация строки обходит статический анализ Vite
            // pagefind генерируется только после `pnpm build`
            const path = '/pagefind' + '/pagefind.js';
            // @ts-ignore
            const mod = await import(path);
            await mod.init();
            pagefind = mod;
            return pagefind;
        } catch { return null; }
    }

    function init() {
        const overlay    = document.getElementById('search-overlay');
        const input      = document.getElementById('search-input') as HTMLInputElement;
        const closeBtn   = document.getElementById('search-close');
        const list       = document.getElementById('search-list');
        const stEmpty    = document.getElementById('search-state-empty');
        const stLoading  = document.getElementById('search-state-loading');
        const stNoResult = document.getElementById('search-state-empty-results');
        if (!overlay || !input || !list) return;

        let timer: ReturnType<typeof setTimeout>;

        function open() {
            overlay!.style.display = 'flex';
            requestAnimationFrame(() => overlay!.classList.add('visible'));
            input.focus();
            document.body.style.overflow = 'hidden';
            loadPagefind();
        }

        function close() {
            overlay!.classList.remove('visible');
            setTimeout(() => {
                overlay!.style.display = 'none';
                input.value = '';
                setState('empty');
            }, 150);
            document.body.style.overflow = '';
        }

        function setState(s: 'empty' | 'loading' | 'no-results' | 'results') {
            stEmpty?.classList.toggle('hidden', s !== 'empty');
            stLoading?.classList.toggle('hidden', s !== 'loading');
            stNoResult?.classList.toggle('hidden', s !== 'no-results');
            list?.classList.toggle('hidden', s !== 'results');
        }

        async function search(q: string) {
            if (!q.trim()) { setState('empty'); return; }
            setState('loading');
            const pf = await loadPagefind();
            if (!pf) {
                if (import.meta.env.DEV) {
                    stNoResult!.innerHTML = '<p style="padding:2rem;text-align:center;color:var(--text-muted);font-size:0.875rem">Поиск недоступен в dev-режиме.<br>Запустите <code>pnpm build && pnpm preview</code></p>';
                    setState('no-results');
                } else { setState('no-results'); }
                return;
            }
            try {
                const { results } = await pf.search(q);
                if (!results.length) { setState('no-results'); return; }
                list!.innerHTML = '';
                for (const r of results.slice(0, 10)) {
                    const d = await r.data();
                    const li = document.createElement('li');
                    const a = document.createElement('a');
                    a.href = d.url;
                    a.className = 'search-result';
                    a.innerHTML = `<p class="search-result-title">${d.meta.title || 'Без названия'}</p>${d.excerpt ? `<p class="search-result-excerpt">${d.excerpt}</p>` : ''}`;
                    li.appendChild(a);
                    list!.appendChild(li);
                }
                setState('results');
            } catch { setState('no-results'); }
        }

        input.addEventListener('input', e => {
            clearTimeout(timer);
            timer = setTimeout(() => search((e.target as HTMLInputElement).value), 300);
        });

        closeBtn?.addEventListener('click', close);
        overlay.addEventListener('click', e => { if (e.target === overlay || (e.target as Element).closest('.search-container') === e.target) close(); });
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape' && overlay.classList.contains('visible')) close();
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); open(); }
        });

        window.openSearchModal = open;
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
</script>

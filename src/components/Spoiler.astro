---
interface Props {
    title?: string;
}

const { title = 'Спойлер' } = Astro.props;

const accent = '#a855f7';
---

<details class="spoiler" style={`--spoiler-accent: ${accent}`}>
    <summary class="spoiler-summary">
        <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
        >
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
            <circle cx="12" cy="12" r="3"></circle>
        </svg>
        <span class="spoiler-title">{title}</span>
        <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="spoiler-chevron"
            aria-hidden="true"
        >
            <path d="M9 18l6-6-6-6"></path>
        </svg>
    </summary>
    <div class="spoiler-body">
        <slot />
    </div>
</details>

<style>
    .spoiler {
        border: 1px solid
            color-mix(in srgb, var(--spoiler-accent) 35%, transparent);
        border-left: 4px solid var(--spoiler-accent);
        background: color-mix(
            in srgb,
            var(--spoiler-accent) 10%,
            var(--bg-card)
        );
        border-radius: 0 0.5rem 0.5rem 0;
        margin: 2rem 0;
        box-shadow: 0 1px 4px
            color-mix(in srgb, var(--spoiler-accent) 12%, transparent);
    }

    .spoiler-summary {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 1.125rem 1.375rem;
        color: var(--spoiler-accent);
        cursor: pointer;
        user-select: none;
        list-style: none;
    }

    .spoiler-summary::-webkit-details-marker {
        display: none;
    }

    .spoiler-title {
        font-size: 0.875rem;
        font-weight: 700;
        flex: 1;
    }

    .spoiler-chevron {
        transition: transform 0.2s ease;
        opacity: 0.7;
    }

    .spoiler[open] .spoiler-chevron {
        transform: rotate(90deg);
    }

    .spoiler-body {
        padding: 0 1.375rem 1.125rem;
        color: var(--text-dim);
        line-height: 1.6;
    }

    .spoiler-body :global(p) {
        margin: 0 0 0.625rem;
    }

    .spoiler-body :global(p:last-child) {
        margin-bottom: 0;
    }
</style>

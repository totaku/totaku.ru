---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type Layout = 'single' | 'double' | 'grid';
type AspectRatio = '16/9' | '4/3' | '3/2' | '1/1' | 'auto';

interface Props {
    images: ImageMetadata[] | { src: ImageMetadata; alt?: string }[];
    layout: Layout;
    caption?: string;
    aspectRatio?: AspectRatio;
    alt?: string[] | ((i: number) => string) | string;
}

const { images, layout, caption, aspectRatio = '16/9', alt } = Astro.props;

function isImageWithAlt(img: unknown): img is { src: ImageMetadata; alt?: string } {
    return typeof img === 'object' && img !== null && 'src' in img && typeof (img as any).src === 'object' && 'width' in (img as any).src;
}

const normalized = (images as (ImageMetadata | { src: ImageMetadata; alt?: string })[]).map((img, i) => {
    if (isImageWithAlt(img)) return img;
    let altText = '';
    if (Array.isArray(alt)) altText = alt[i] ?? '';
    else if (typeof alt === 'function') altText = alt(i);
    else if (typeof alt === 'string') altText = alt;
    return { src: img as ImageMetadata, alt: altText };
});

const visibleCount = 5;
const showOverlay = images.length > 6;
const remainingCount = Math.max(0, images.length - visibleCount);

const gridClass = layout === 'single' ? 'gallery-single' : layout === 'double' ? 'gallery-double' : 'gallery-grid';
const arClass = `ar-${aspectRatio.replace('/', '-')}`;
---

<figure class="gallery-figure">
    <div class={`pswp-gallery ${gridClass}`}>
        {normalized.map((img: { src: ImageMetadata; alt?: string }, i: number) => (
            <Fragment>
                {i < (showOverlay ? visibleCount + 1 : images.length) && (
                    <a
                        href={img.src.src}
                        data-pswp-width={img.src.width}
                        data-pswp-height={img.src.height}
                        class={`gallery-item ${arClass}`}
                    >
                        <Picture
                            src={img.src}
                            alt={img.alt || ''}
                            formats={['avif', 'webp', 'jpeg']}
                            widths={[400, 800, 1200]}
                            loading="lazy"
                            decoding="async"
                            class={i === visibleCount && showOverlay ? 'brightness-50' : ''}
                            sizes={layout === 'single' ? '(max-width: 1200px) 100vw, 1200px' : layout === 'double' ? '(max-width: 768px) 100vw, 50vw' : '(max-width: 768px) 100vw, 33vw'}
                        />
                        {i === visibleCount && showOverlay && (
                            <div class="gallery-overlay">+{remainingCount}</div>
                        )}
                    </a>
                )}
                {i >= (showOverlay ? visibleCount + 1 : images.length) && (
                    <a href={img.src.src} data-pswp-width={img.src.width} data-pswp-height={img.src.height} style="display:none" />
                )}
            </Fragment>
        ))}
    </div>
    {caption && <figcaption class="gallery-caption">{caption}</figcaption>}
</figure>

<style>
    .gallery-figure {
        margin: 2rem 0;
    }

    .pswp-gallery {
        display: grid;
        gap: 0.5rem;
    }

    .gallery-single { grid-template-columns: 1fr; }
    .gallery-double { grid-template-columns: 1fr; }
    @media (min-width: 640px) { .gallery-double { grid-template-columns: 1fr 1fr; } }
    .gallery-grid { grid-template-columns: 1fr 1fr; }
    @media (min-width: 768px) { .gallery-grid { grid-template-columns: repeat(3, 1fr); } }

    .gallery-item {
        display: block;
        position: relative;
        overflow: hidden;
        border-radius: 0.5rem;
        width: 100%;
    }

    .ar-16-9  { aspect-ratio: 16/9; }
    .ar-4-3   { aspect-ratio: 4/3; }
    .ar-3-2   { aspect-ratio: 3/2; }
    .ar-1-1   { aspect-ratio: 1/1; }
    .ar-auto  { aspect-ratio: auto; }

    .pswp-gallery a,
    .pswp-gallery picture,
    .pswp-gallery img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        margin: 0;
        padding: 0;
    }

    .gallery-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.4);
        border-radius: 0.5rem;
        font-size: 2.5rem;
        font-weight: 700;
        color: #fff;
    }

    .gallery-caption {
        font-size: 0.8125rem;
        color: var(--text-muted);
        text-align: center;
        margin-top: 0.5rem;
    }
</style>

<script>
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';

    function initGalleries() {
        document.querySelectorAll<HTMLElement>('.pswp-gallery').forEach(gallery => {
            const lightbox = new PhotoSwipeLightbox({
                gallery,
                children: 'a[data-pswp-width]',
                pswpModule: () => import('photoswipe'),
            });
            lightbox.init();
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initGalleries);
    } else {
        initGalleries();
    }
</script>

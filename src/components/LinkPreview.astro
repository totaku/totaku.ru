---
import { parse } from 'node-html-parser';

interface Props {
    url: string;
    showImage?: boolean;
    customImage?: string;
    showUrl?: boolean;
    customDescription?: string;
    class?: string;
}

const {
    url,
    showImage = true,
    customImage,
    showUrl = false,
    customDescription,
    class: extraClass = '',
} = Astro.props;

interface Metadata {
    title: string;
    description: string;
    image: string;
}

async function fetchMetadata(url: string): Promise<Metadata> {
    try {
        const res = await fetch(url, { signal: AbortSignal.timeout(5000) });
        const html = await res.text();
        const doc = parse(html);

        const title =
            doc.querySelector('meta[property="og:title"]')?.getAttribute('content') ||
            doc.querySelector('title')?.text || '';

        const description =
            doc.querySelector('meta[property="og:description"]')?.getAttribute('content') ||
            doc.querySelector('meta[name="description"]')?.getAttribute('content') || '';

        const image =
            doc.querySelector('meta[property="og:image"]')?.getAttribute('content') || '';

        return { title, description, image };
    } catch {
        return { title: '', description: '', image: '' };
    }
}

const meta = await fetchMetadata(url);
const displayImage = customImage || meta.image;
const displayDesc = customDescription || meta.description;
---

<a href={url} target="_blank" rel="noopener noreferrer" class:list={['link-preview', extraClass]}>
    <div class="link-preview-body">
        <p class="link-preview-title">{meta.title || url}</p>
        {displayDesc && <p class="link-preview-desc">{displayDesc}</p>}
        {showUrl && <p class="link-preview-url">{url}</p>}
    </div>
    {showImage && displayImage && (
        <div class="link-preview-image">
            <img src={displayImage} alt={meta.title || 'Preview'} loading="lazy" decoding="async" />
        </div>
    )}
</a>

<style>
    .link-preview {
        display: flex;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 0.625rem;
        overflow: hidden;
        text-decoration: none;
        margin: 1.5rem 0;
        transition: border-color 0.2s;
    }

    .link-preview:hover {
        border-color: var(--accent);
    }

    .link-preview-body {
        flex: 1;
        padding: 1.125rem 1.25rem;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
    }

    .link-preview-title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text);
        margin: 0;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color 0.15s;
    }

    .link-preview:hover .link-preview-title { color: var(--accent); }

    .link-preview-desc {
        font-size: 0.8125rem;
        color: var(--text-dim);
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.5;
    }

    .link-preview-url {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .link-preview-image {
        width: 38%;
        flex-shrink: 0;
    }

    .link-preview-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        margin: 0;
    }
</style>

---
interface Props {
    title?: string;
    variant?: 'info' | 'warning' | 'tip' | 'danger';
    class?: string;
}

const { title, variant = 'info', class: extraClass = '' } = Astro.props;

const icons: Record<string, string> = {
    info: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    warning:
        'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
    tip: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
    danger: 'M12 8v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z',
};

const accentColors: Record<string, string> = {
    info: 'var(--accent)',
    warning: '#f59e0b',
    tip: '#10b981',
    danger: '#ef4444',
};
---

<div
    class:list={['info-block', `info-block--${variant}`, extraClass]}
    style={`--block-accent: ${accentColors[variant]}`}
>
    {
        title && (
            <div class="info-block-header">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <path d={icons[variant]} />
                </svg>
                <span class="info-block-title">{title}</span>
            </div>
        )
    }
    <div class="info-block-body">
        <slot />
    </div>
</div>

<style>
    .info-block {
        border: 1px solid
            color-mix(in srgb, var(--block-accent) 35%, transparent);
        border-left: 4px solid var(--block-accent);
        background: color-mix(in srgb, var(--block-accent) 10%, var(--bg-card));
        border-radius: 0 0.5rem 0.5rem 0;
        padding: 1.125rem 1.375rem;
        margin: 2rem 0;
        box-shadow: 0 1px 4px color-mix(in srgb, var(--block-accent) 12%, transparent);
    }

    .info-block-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.625rem;
        color: var(--block-accent);
    }

    .info-block-title {
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--block-accent);
    }

    .info-block-body {
        color: var(--text-dim);
        line-height: 1.6;
    }

    .info-block-body :global(p) {
        margin: 0 0 0.625rem;
    }

    .info-block-body :global(p:last-child) {
        margin-bottom: 0;
    }

    .info-block-body :global(ul),
    .info-block-body :global(ol) {
        margin: 0.5rem 0;
        padding-left: 1.25rem;
    }

    .info-block-body :global(li) {
        margin-bottom: 0.25rem;
    }

    .info-block-body :global(code) {
        background: color-mix(in srgb, var(--block-accent) 15%, transparent);
        padding: 0.125rem 0.375rem;
        border-radius: 0.25rem;
        font-size: 0.8125rem;
    }
</style>

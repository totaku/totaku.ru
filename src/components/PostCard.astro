---
import type { CollectionEntry } from 'astro:content';
import { Picture } from 'astro:assets';
import { transliterate } from '@/utils/transliterate';

interface Props {
    post: CollectionEntry<'posts'>;
    animDelay?: number;
}

const { post, animDelay = 0 } = Astro.props;

const catName = post.data.categories[0] ?? '';
const catSlug = catName ? transliterate(catName) : 'other';

const dateFormatted = post.data.date.toLocaleDateString('ru-RU', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
});
---

<article class="card" style={`animation-delay:${animDelay}s`}>
    <div class="card-cover">
        {
            post.data.featuredImage ? (
                <Picture
                    src={post.data.featuredImage}
                    alt={post.data.title}
                    widths={[400, 600, 800]}
                    formats={['avif', 'webp', 'jpeg']}
                    loading="lazy"
                    decoding="async"
                />
            ) : (
                <div class={`card-cover-placeholder placeholder-${catSlug}`}>
                    {catName}
                </div>
            )
        }
    </div>
    <div class="card-body">
        <div class="card-title">
            <a class="card-link" href={`/${post.id}/`} data-astro-prefetch>{post.data.title}</a>
        </div>
        {
            post.data.description && (
                <div class="card-desc">{post.data.description}</div>
            )
        }
        <div class="card-footer">
            <span class="card-date">{dateFormatted}</span>
            <a class="card-cat" href={`/categories/${catSlug}/`}>{catName}</a>
        </div>
    </div>
</article>

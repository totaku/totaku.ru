---
import type { CollectionEntry } from 'astro:content';
import { getImage } from 'astro:assets';
import { transliterate } from '@/utils/transliterate';

interface Props {
  post: CollectionEntry<'posts'>;
  animDelay?: number;
}

const { post, animDelay = 0 } = Astro.props;

const catName = post.data.categories[0] ?? '';
const catSlug = catName ? transliterate(catName) : 'other';

const dateFormatted = post.data.date.toLocaleDateString('ru-RU', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
});

let coverSrc = '';
if (post.data.featuredImage) {
  const img = await getImage({
    src: post.data.featuredImage,
    width: 600,
    format: 'webp',
  });
  coverSrc = img.src;
}
---

<a class="card" href={`/${post.id}/`} style={`animation-delay:${animDelay}s`}>
  <div class="card-cover">
    {
      coverSrc ? (
        <img
          src={coverSrc}
          alt={post.data.title}
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class={`card-cover-placeholder placeholder-${catSlug}`}>
          {catName}
        </div>
      )
    }
  </div>
  <div class="card-body">
    <div class="card-title">{post.data.title}</div>
    {
      post.data.description && (
        <div class="card-desc">{post.data.description}</div>
      )
    }
    <div class="card-footer">
      <span class="card-date">{dateFormatted}</span>
      <span
        class="card-cat"
        data-href={`/categories/${catSlug}/`}
        onclick="event.stopPropagation();window.location.href=this.dataset.href"
        >{catName}</span
      >
    </div>
  </div>
</a>
